# ============================================================
# AWS S3 Configuration
# ============================================================
S3_BUCKET_NAME=your-bucket-name
AWS_REGION=eu-west-3

# ============================================================
# AWS RDS / PostgreSQL Configuration
# ============================================================
RDS_HOST=your-rds-endpoint.rds.amazonaws.com
RDS_PORT=5432
RDS_DB_NAME=kayak_db
RDS_USER=kayak_user
RDS_PASSWORD=your_password_here
RDS_SCHEMA=public
